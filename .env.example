# Pi-hole admin UI password
FTLCONF_webserver_api_password=CHANGE_ME

# This machine's LAN IP address (shown in Pi-hole and used for ServerIP)
SERVER_IP=192.168.50.254

# Restrict admin UI access to localhost + your LAN subnet
# Adjust the subnet to match your network (e.g. 192.168.1.0/24)
FTLCONF_webserver_acl=+127.0.0.1,+[::1],+192.168.50.0/24,+172.30.0.0/24
